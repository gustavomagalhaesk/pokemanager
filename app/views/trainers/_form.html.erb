<%= form_with(model: trainer, html: { class: "shadow-sm p-4 border rounded bg-white" }) do |form| %>
  
  <% if trainer.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="alert-heading"><%= pluralize(trainer.errors.count, "erro") %> impediram este treinador de ser salvo:</h4>
      <ul class="mb-0">
        <% trainer.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Nome do Treinador", class: "form-label fw-bold" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Ex: Ash Ketchum" %>
  </div>

  <div class="mb-3">
    <%= form.label :money, "Dinheiro Inicial", class: "form-label fw-bold" %>
    <div class="input-group">
      <span class="input-group-text">$</span>
      <%= form.text_field :money, class: "form-control", placeholder: "0.00" %>
    </div>
  </div>

  <div class="mb-4">
    <%= form.label :url_image, "URL da Imagem de Perfil", class: "form-label fw-bold" %>
    <%= form.text_field :url_image, class: "form-control", placeholder: "https://exemplo.com/foto.png" %>
  </div>

  <div class="d-grid gap-2">
    <%= form.submit "Salvar Treinador", class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancelar", trainers_path, class: "btn btn-outline-secondary" %>
  </div>

<% end %>
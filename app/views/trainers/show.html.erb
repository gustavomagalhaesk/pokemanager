<div class="">
  <p style="color: green"><%= notice %></p>

  <div class="d-flex justify-content-center">
    <div class="bg-light rounded p-2 w-75 border">
      <%= link_to '', trainers_path, class:"btn btn-primary bi bi-caret-left-fill" %>
      <%= link_to 'Delete Trainer', @trainer, method: :delete, class:"btn btn-primary" %>
      <%= link_to 'Edit Trainer', edit_trainer_path(@trainer), class:"btn btn-primary" %>
      <div class="pt-2 row d-flex justify-content-center">
        <img src="<%= @trainer.url_image%>" class="w-25">
        <div class="col">
          <h1><%= @trainer.name %></h1>
          <h1 class="text-success">$<%= @trainer.money %></h1>
          <div class="w-50">
            <button class="btn btn-primary">
              <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/poke-ball.png">
              <%= link_to '', new_pokemon_path, class:"link-offset-2 link-underline link-underline-opacity-0"%>
              Catch a Pokemon
            </button>

            <button class="btn btn-primary">
              <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/items/rare-candy.png">
              <%= link_to '', new_pokemon_path, class:"link-offset-2 link-underline link-underline-opacity-0"%>
              Level up a pokemon
            </button>
          </div>
        </div>
        <div>
          <div class="rounded p-1">
            <div class="row p-2">
              <%@pokemons.where(trainer_id: @trainer).each do |pokemon|%>
                <div class="border rounded mt-1">
                  <div class="row rounded border-start border-4 <%= type_color(pokemon.pokedex.pk_type)%>">
                    <div class="col-2 text-center">
                      <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/<%= pokemon.pokedex_id %>.png">
                    </div>
                    <div class="col-8 p-2">
                      <h6 class="mb-0"><%= pokemon.pokedex.name %></h6>
                      <p class="mb-0"><%= pokemon.pokedex.pk_type %></p>
                      <p> Lvl: <%= pokemon.level %></p>
                    </div>
                    <div class="col border p-1">
                      editar e exlcluir pokemons |botões|
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
          <h1>teste</h1>
        </div>
      </div>
    </div>

  </div>
</div>

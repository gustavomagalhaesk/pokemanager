<p style="color: green"><%= notice %></p>

<%= render @trainer %>

<div>
  <%= link_to "Edit this trainer", edit_trainer_path(@trainer) %> |
  <%= link_to "Back to trainers", trainers_path %>
  <% @pokemons.each do |pokemon| %>
  <ul>
    <li><%= pokemon.pokedex.name %>|<%= pokemon.pokedex.pk_type %></li>
  </ul>
  <% end %>
  <%= button_to "Destroy this trainer", @trainer, method: :delete %>
</div>

<div class="">
  <p style="color: green"><%= notice %></p>
  <% content_for :title, "Trainers" %>

  <h2 class="row bg-info text-light shadow justify-content-center">Trainers</h2>

  <div class="container">
    <% @trainers.each do |trainer|%>
    <div class="row mt-2 rounded shadow-sm p-3 border">
      <div class="d-grid col-2 text-center">
        <img src="<%= trainer.url_image %>" class="rounded img-fluid">
        <h5 class="text-success mt-1">$<%= trainer.money %></h5>
      </div>  
      <div class="col">
        <div class="row">
          <h3 class="col"><%= trainer.name %></h3>
          <span class="col text-end pl-0"><%= link_to 'Show this Trainer', trainer, class:"btn btn-light"%></span>
        </div>
        <div class="row">
          <%@pokemons.where(trainer_id: trainer).each do |pokemon|%>
            <div class="col-md-auto text-center">
              <img src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/<%= pokemon.pokedex_id %>.png"
              class="border-bottom border-3 <%= type_color(pokemon.pokedex.pk_type)%>" >
              <p class="mb-0"><%= pokemon.pokedex.name %></p>
              <p class="mb-0"><%= pokemon.pokedex.pk_type %></p>
            </div>
          <% end %>
        </div>
      </div> 
    </div>
    <% end %>
  </div>
</div>

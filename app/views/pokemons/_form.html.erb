<%= form_with(model: pokemon) do |form| %>
  <% if pokemon.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(pokemon.errors.count, "error") %> prohibited this pokemon from being saved:</h2>

      <ul>
        <% pokemon.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :trainer_id, style: "display: block" %>
    <%= form.text_field :trainer_id %>
  </div>

  <div>
    <%= form.label :pokedex_id, style: "display: block" %>
    <%= form.text_field :pokedex_id %>
  </div>

  <div>
    <%= form.label :level, style: "display: block" %>
    <%= form.number_field :level %>
  </div>

  <div>
    <%= form.label :on_team, style: "display: block" %>
    <%= form.checkbox :on_team %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
